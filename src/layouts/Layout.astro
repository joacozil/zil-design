---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Zil Design",
  description = "Zil Design — a strategic design agency.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon-darkmode.svg"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {
      /* Arms the scroll entrances. This is the ONE place that decides whether any
        element is allowed to start hidden; global.css hides only from
        `html.reveal-armed`, and scripts/reveal.ts animates only if this class is
        present, so the decision cannot be made twice and drift.

        It must stay INLINE and in <head>. Inline is what puts the decision before
        first paint: a deferred module would let the page render, then yank content
        away to animate it in.

        Three readers get the finished page precisely because they never reach
        `add()`:
          · no JS at all, and crawlers that don't run it — the class never lands.
          · prefers-reduced-motion — nothing hides, so nothing needs revealing.
          · a document that is HIDDEN at load: a tab opened in the background, a
            headless renderer. GSAP's ticker is requestAnimationFrame-driven, so
            in a hidden document tweens never advance — arming there would hide
            every element behind an animation that cannot run and leave the page
            blank. HeroFloaters guards the same trap for the same reason; the
            trade is that a background-opened tab shows a composed page with no
            entrance, which is the right way to fail. */
    }
    <script is:inline>
      if (
        document.visibilityState === "visible" &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        document.documentElement.classList.add("reveal-armed");
      }
    </script>
    {/* Preload the two most-used weights to avoid a flash of fallback text. */}
    <link
      rel="preload"
      href="/fonts/CircularStd-Book.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/CircularStd-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    {
      /* Scroll entrances for the whole site. Declarative: sections opt in with
        `data-reveal` attributes and this engine drives them. See scripts/reveal.ts. */
    }
    <script>
      import "../scripts/reveal";
    </script>

    <script>
      /**
       * Smooth in-page anchor scrolling.
       *
       * This lives here rather than as `html { scroll-behavior: smooth }` in
       * global.css on purpose. GSAP ScrollTrigger writes an inline
       * `scroll-behavior: auto` on the scroller and relies on it: every
       * `refresh()` jumps the page to 0 to measure natural offsets and jumps
       * back, and both hops have to be instant. A CSS rule would need
       * `!important` to beat that inline style, which animates the jump to 0 —
       * a visible flight to the top, and on iOS Safari the restore can be
       * cancelled by touch/momentum, stranding the reader there.
       *
       * Passing `behavior` explicitly overrides the computed `auto` for this one
       * call, so anchors smooth-scroll and GSAP keeps its instant writes.
       */
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );

      document.addEventListener("click", (event) => {
        // The mobile menu closes itself first and then runs its own scroll.
        if (event.defaultPrevented) return;
        const el = event.target as HTMLElement | null;
        const link = el?.closest<HTMLAnchorElement>('a[href^="#"]');
        const hash = link?.getAttribute("href");
        if (!hash || hash.length < 2) return;
        const dest = document.querySelector(hash);
        if (!dest) return;

        event.preventDefault();
        // scrollIntoView honours `scroll-padding-top` and the `.scroll-anchor`
        // scroll-margin, so targets clear the fixed header exactly as before.
        dest.scrollIntoView({
          behavior: reduceMotion.matches ? "auto" : "smooth",
          block: "start",
        });
        history.pushState(null, "", hash);
      });
    </script>
  </body>
</html>
