---
import ClaimText from "../components/react/ClaimText.tsx";

const claim =
  "Cada punto de contacto comunica. Cuando no existe una estrategia detrás, se pierden oportunidades de crecimiento y diferenciación.";
---

<section id="claim" class="border-t border-border/60">
  <div
    class="mx-auto flex min-h-[100svh] w-full max-w-6xl items-center px-6 py-24 tablet:px-8 desktop:px-12"
  >
    <ClaimText
      client:load
      text={claim}
      className="max-w-[24ch] text-h2 font-medium text-pretty text-text"
    />
  </div>
</section>
