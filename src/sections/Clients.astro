---
import ClientsMarquee from "../components/react/ClientsMarquee.tsx";
import mmg from "../assets/img/mmg.svg";
import quantia from "../assets/img/quantia.svg";
import clojure from "../assets/img/clojure.svg";
import netValue from "../assets/img/net-value.svg";
import advantia from "../assets/img/advantia.svg";
import nu from "../assets/img/nu.svg";

// `h` is a per-logo height class — logos are normalized by height, but some
// marks read smaller at the same height, so they get a larger value.
const logos = [
  { img: nu, alt: "Nu", h: "h-8" },
  { img: mmg, alt: "MMG Bank", h: "h-7" },
  { img: advantia, alt: "Advantia", h: "h-10" },
  { img: quantia, alt: "Quantia", h: "h-7" },
  { img: clojure, alt: "Clojure", h: "h-9" },
  { img: netValue, alt: "Net Value", h: "h-10" },
];

// Plain, serializable data for the marquee island.
const marqueeLogos = logos.map(({ img, alt, h }) => ({ src: img.src, alt, h }));
---

<section id="clients" class="border-t border-border/60 py-14 tablet:py-16">
  {
    /* Full-bleed infinite marquee on all breakpoints. `client:load` so the
      auto-scroll is already running by the time the section scrolls into view. */
  }
  <ClientsMarquee client:load logos={marqueeLogos} />
</section>
