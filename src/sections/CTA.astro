---
import Button from "../components/astro/Button.astro";

// Shared classes for the white fields so every input/textarea matches.
const fieldBase =
  "w-full rounded-2xl bg-surface px-6 py-4 text-p text-text placeholder:text-p placeholder:font-normal placeholder:text-gray focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-primary-light";
---

<section>
  <div
    class="mx-auto w-full max-w-8xl px-6 py-section tablet:px-8 desktop:px-12"
  >
    <div id="cta" class="scroll-anchor"></div>

    <div class="rounded-3xl bg-primary-light p-8 tablet:p-12 desktop:p-16">
      <div class="grid grid-cols-1 gap-10 desktop:grid-cols-2 desktop:gap-16">
        {/* Left — intro */}
        <div>
          <h2 class="max-w-[16ch] text-h2 tracking-[-0.03em] text-balance">
            Hablemos de tu marca
          </h2>
          <p class="mt-4 max-w-[36ch] text-p-lg text-pretty">
            Descubre el potencial de tu marca que todavía no está aprovechado.
          </p>
        </div>

        {/* Right — contact form */}
        <form class="flex flex-col gap-4">
          <input
            type="text"
            name="nombre"
            required
            placeholder="Tu nombre"
            autocomplete="name"
            class={fieldBase}
          />
          <input
            type="text"
            name="empresa"
            placeholder="¿De qué empresa venís?"
            autocomplete="organization"
            class={fieldBase}
          />
          <input
            type="email"
            name="email"
            required
            placeholder="Email"
            autocomplete="email"
            class={fieldBase}
          />
          <input
            type="tel"
            name="celular"
            placeholder="Celular"
            autocomplete="tel"
            class={fieldBase}
          />
          <textarea
            name="mensaje"
            rows="4"
            placeholder="Contanos brevemente qué necesitas"
            class={`${fieldBase} resize-none`}></textarea>

          <div class="mt-2">
            <Button type="submit" variant="pill-dark">Descubre Zil Design</Button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
