---
import Badge from "../components/astro/Badge.astro";
import ServicesSelector, {
  type Service,
} from "../components/react/ServicesSelector.tsx";
import uxui from "../assets/img/ux-ui-icon.svg";
import webDesign from "../assets/img/web-design-icon.svg";
import branding from "../assets/img/branding-icon.svg";
import socialMedia from "../assets/img/social-media-icon.svg";

// BADGE ORDER IS LOAD-BEARING. On a mobile card the three badges wrap to two
// rows, and the break falls wherever the first two pills stop fitting — so the
// order decides whether a card reads 2-on-top/1-below or 1-on-top/2-below, and
// cards with different orders disagree with each other. Rule: list the two
// NARROWEST labels first, widest last. Web Design was the odd one out (its
// widest, "Organizado", sat second, pushing the pair to 270px against 278px of
// card) — hence Responsive before Organizado below.
//
// This holds the pattern from ~380px up; it is the best ordering can do, since
// on a narrower phone even the two narrowest pills of these two services exceed
// the row. Reword a badge and the widths shift — re-check the order on mobile.
const services: Service[] = [
  {
    name: "UX/UI Design",
    icon: uxui.src,
    text: "Estructuramos la experiencia interactiva de sus plataformas mediante un diseño funcional que optimiza la conversión y el desempeño técnico.",
    badges: ["Usabilidad", "Wireframes", "Prototipado"],
    variant: "lilac",
  },
  {
    name: "Web Design",
    icon: webDesign.src,
    text: "Desarrollamos interfaces digitales de alta precisión que transforman su presencia en un motor comercial continuo y una ventaja competitiva real.",
    badges: ["Interactivo", "Responsive", "Organizado"],
    variant: "lime",
  },
  {
    name: "Branding",
    icon: branding.src,
    text: "Construimos una arquitectura de marca organizada con el fin de proyectar solidez institucional, potenciar su valor y blindar su diferenciación.",
    badges: ["Identidad", "Logotipo", "Estrategia"],
    variant: "dark",
  },
  {
    name: "Social Media",
    icon: socialMedia.src,
    text: "Gestionamos canales digitales con criterio estratégico para transformar la comunicación en una herramienta activa de posicionamiento.",
    badges: ["Contenido", "Campañas", "Community"],
    variant: "primary",
  },
];
---

<section>
  <div
    class="mx-auto w-full max-w-8xl px-6 py-section tablet:px-8 desktop:px-12"
  >
    {/* Header */}
    <div id="servicios" class="scroll-anchor"></div>
    <Badge>Servicios</Badge>
    <h2 class="mt-6 max-w-230 text-h2 tracking-[-0.03em] text-balance">
      Una comunicación visual sin dirección dificulta el crecimiento.
    </h2>
    <p class="mt-4 max-w-190 text-p text-pretty text-muted">
      Es por esto que tener una estrategia clara convierte cada interacción en
      una oportunidad de negocio. En Zil Design trabajamos para potenciar tu
      negocio de forma clara y organizada.
    </p>

    <div class="mt-12 tablet:mt-16">
      <ServicesSelector client:visible services={services} />
    </div>
  </div>
</section>
