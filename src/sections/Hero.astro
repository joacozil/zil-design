---
import HeroFloaters from "../components/react/HeroFloaters.tsx";
import Button from "../components/astro/Button.astro";
---

<section
  id="hero"
  class="relative flex min-h-svh w-full flex-col items-center justify-center overflow-hidden"
>
  <HeroFloaters client:load />

  {/* Viewport-pinned: min-h-svh with centred content, so the section rhythm
      (`py-section`) deliberately does NOT apply here — the space Clients sees
      below is (svh − content) / 2 from the centring, not this padding. The py
      below is only a floor for short viewports, where the content would
      otherwise touch the edges. See the rhythm note in styles/global.css. */}
  <div
    class="relative z-10 mx-auto flex w-full max-w-8xl flex-col items-center px-6 py-16 text-center tablet:px-8 desktop:px-12"
  >
    <h1 class="max-w-[15ch] text-h1 text-balance">
      El diseño como herramienta de negocio
    </h1>

    <p class="mt-6 max-w-[42ch] text-p-lg text-pretty text-muted">
      Diseñamos sistemas visuales que aportan dirección, fortalecen el
      posicionamiento y potencian el valor percibido de tu marca.
    </p>

    <div class="mt-10">
      <Button href="#cta" variant="pill">Hablemos de tu marca</Button>
    </div>
  </div>
</section>
