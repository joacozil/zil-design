---
import Button from "../components/astro/Button.astro";
---

<section
  id="hero"
  class="mx-auto flex min-h-svh w-full max-w-6xl flex-col items-center justify-center px-6 py-16 text-center tablet:px-8 desktop:px-12"
>
  <h1 class="max-w-[15ch] text-h1 text-balance">
    El diseño como herramienta de negocio
  </h1>

  <p class="mt-6 max-w-[42ch] text-p-lg text-pretty text-muted">
    El mercado premia las marcas que comunican con claridad.
  </p>

  <div class="mt-10">
    <Button href="#cta">Hablemos de tu marca</Button>
  </div>
</section>
