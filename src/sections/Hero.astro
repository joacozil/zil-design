---
import Button from "../components/astro/Button.astro";
---

<section
  id="hero"
  class="mx-auto flex min-h-[calc(100svh-5rem)] w-full max-w-6xl flex-col items-center justify-center px-6 py-16 text-center tablet:px-8 desktop:px-12"
>
  <h1 class="max-w-[15ch] text-h1 text-balance">
    El lado comercial de tu marca, resuelto.
  </h1>

  <p class="mt-6 max-w-[42ch] text-p-lg text-pretty text-muted">
    Estrategia, creatividad, medios y tecnología en una sola operación.
  </p>

  <div class="mt-10">
    <Button href="#cta">Hablemos de tu marca</Button>
  </div>
</section>
