---
import { getImage } from "astro:assets";
import Badge from "../components/astro/Badge.astro";
import ProjectsSlider from "../components/react/ProjectsSlider.tsx";
import mmg from "../assets/img/mmg.jpg";
import quantia from "../assets/img/quantia.jpg";
import clojure from "../assets/img/clojure.jpg";
import gelato from "../assets/img/gelato.jpg";
import advantia from "../assets/img/advantia.jpg";

// TODO: confirm final categories from Figma.
const projects = [
  { img: mmg, name: "MMG Bank", category: "Institucional" },
  { img: quantia, name: "Quantia", category: "Producto Digital" },
  { img: clojure, name: "Clojure", category: "Branding" },
  { img: gelato, name: "Gelato", category: "Branding" },
  { img: advantia, name: "Advantia", category: "Institucional" },
];

// Optimize once at build time (some sources are >2MB); pass plain srcs to the
// island. Keep the source (landscape) aspect; the 3:2 card crops via object-cover.
const optimized = await Promise.all(
  projects.map(async ({ img, name, category }) => {
    const image = await getImage({ src: img, width: 1200, format: "webp" });
    return { src: image.src, name, category };
  }),
);
---

<section
  id="work"
  class="py-20 tablet:py-28 desktop:py-32"
>
  {/* Header (aligned with the container; the slider below is full-bleed) */}
  <div class="mx-auto w-full max-w-8xl px-6 tablet:px-8 desktop:px-12">
    <Badge>Nuestros proyectos</Badge>
    <h2
      class="mt-6 max-w-7xl text-h2 tracking-[-0.03em] text-balance"
    >
      Cada punto de contacto comunica.
    </h2>
    <p class="mt-4 max-w-190 text-p text-pretty text-muted">
      Sin una estrategia detrás, se pierden oportunidades de crecimiento y
      diferenciación. En Zil Design te ayudamos a encontrar tus fortalezas y
      llevarlas a la superficie.
    </p>
  </div>

  <div class="mt-12 tablet:mt-16">
    <ProjectsSlider client:visible projects={optimized} />
  </div>
</section>
