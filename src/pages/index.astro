---
import Layout from "../layouts/Layout.astro";
import Header from "../components/astro/Header.astro";
import Hero from "../sections/Hero.astro";
import Clients from "../sections/Clients.astro";
import Projects from "../sections/Projects.astro";
import Services from "../sections/Services.astro";
import Statement from "../sections/Statement.astro";
import SystemToggleSection from "../sections/SystemToggle.astro";
import HowWeWork from "../sections/HowWeWork.astro";
import FAQ from "../sections/FAQ.astro";
import CTA from "../sections/CTA.astro";
import Footer from "../components/astro/Footer.astro";
import ContactDrawer from "../components/astro/ContactDrawer.astro";
---

<Layout title="Zil Design">
  <Header />
  <main>
    <Hero />
    <Clients />
    <SystemToggleSection />
    <Projects />
    <!-- <Statement /> -->
    <HowWeWork />
    <Services />
    <CTA />
    <FAQ />
  </main>
  <Footer />
  {
    /* Mobile / tablet only — the persistent invitation to contact. Mounted here
      rather than in Layout because it observes this page's #cta section. */
  }
  <ContactDrawer />
</Layout>
