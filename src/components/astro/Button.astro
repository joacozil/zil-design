---
/**
 * Reusable button / link. Renders an <a> when `href` is given, otherwise a
 * <button>. Every button on the site uses one of these variants.
 *
 * Variants:
 *  - pill        → Hero CTA (bg-accent, primary arrow circle w/ white arrow on hover)
 *  - pill-dark   → Form submit (bg-primary-dark, light arrow circle on hover)
 *  - pill-sm     → compact pill, no arrow. Currently unused: it was the mobile
 *                  header's Contacto, which ContactDrawer replaced.
 *  - outline     → Footer "Ir Arriba" (border-primary, arrow slides up on hover)
 *  - primary     → Generic dark button
 *  - secondary   → Generic light button
 */
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?:
    "pill" | "pill-dark" | "pill-sm" | "outline" | "primary" | "secondary";
  class?: string;
  arrowDirection?: "right" | "up";
}

const {
  href,
  type = "button",
  variant = "primary",
  class: className = "",
  arrowDirection = "right",
} = Astro.props;

const hasPillArrow = variant === "pill" || variant === "pill-dark";
const hasOutlineArrow = variant === "outline";
const hasArrow = hasPillArrow || hasOutlineArrow;

const Tag = href ? "a" : "button";

const arrowPaths: Record<string, string> = {
  right: "M5 12h14M13 6l6 6-6 6",
  up: "M12 19V5M6 11l6-6 6 6",
};

const variantClasses: Record<string, string> = {
  pill: "bg-accent  py-4 pr-9 pl-9 text-p-lg font-medium transition-[padding] duration-300 ease-out desktop:hover:pr-[4.5rem] focus-visible:ring-primary focus-visible:ring-offset-surface",
  "pill-dark":
    "bg-primary-dark py-4 pr-9 pl-9 text-p-lg font-medium text-text-inverse transition-[padding] duration-300 ease-out desktop:hover:pr-[3.75rem] focus-visible:ring-primary-dark focus-visible:ring-offset-primary-light",
  "pill-sm":
    "bg-primary px-5 py-2.5 text-p-sm font-medium text-text-inverse transition-colors duration-200",
  // pr/pl split (not px-8) so the hover growth cleanly overrides only the right
  // side. pr 32 → 52 opens exactly 20px for the arrow. mr-5 at rest reserves
  // 20px of space that collapses to 0 on hover, so the button grows RIGHTWARD
  // into its own margin — matching the pill CTAs — even when flex-pinned right.
  outline:
    "border-2 border-primary py-3 pr-8 pl-8 mr-5 text-p-sm font-medium text-text-inverse transition-[padding,margin] duration-300 ease-out desktop:hover:pr-13 desktop:hover:mr-0 focus-visible:ring-primary focus-visible:ring-offset-primary-dark",
  primary:
    "bg-surface-inverse px-7 py-3.5 text-p font-medium text-text-inverse transition-[transform,background-color,box-shadow] duration-200 ease-out hover:-translate-y-0.5 hover:bg-surface-inverse/90 hover:shadow-md active:translate-y-0 focus-visible:ring-primary focus-visible:ring-offset-surface",
  secondary:
    "bg-primary-light px-7 py-3.5 text-p font-medium text-primary-dark transition-[transform,background-color,box-shadow] duration-200 ease-out hover:-translate-y-0.5 hover:bg-primary-light/80 active:translate-y-0 focus-visible:ring-primary focus-visible:ring-offset-surface",
};

const circleClasses: Record<string, string> = {
  // pill sits on `bg-accent`, where a white circle reads washed out — so its
  // circle is primary with a white arrow. pill-dark / outline sit on dark
  // backgrounds where the white circle still holds.
  pill: "bg-primary text-text-inverse",
  "pill-dark": "bg-white text-primary",
  outline: "bg-white text-primary",
};

const base =
  "group relative inline-flex cursor-pointer items-center overflow-hidden rounded-full focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none motion-reduce:transition-none";

const cls = [base, variantClasses[variant], className]
  .filter(Boolean)
  .join(" ");
---

<Tag class={cls} {...href ? { href } : { type }}>
  {
    hasPillArrow ? (
      <>
        <span
          class:list={[
            "transition-[translate] duration-300 ease-out motion-reduce:transition-none",
            variant === "pill-dark" && "desktop:group-hover:-translate-x-2",
          ]}
        >
          <slot />
        </span>
        <span
          aria-hidden="true"
          class:list={[
            "pointer-events-none absolute top-1/2 right-2 grid size-12 translate-x-[160%] -translate-y-1/2 place-items-center rounded-full opacity-0 transition-[translate,opacity] duration-300 ease-out motion-reduce:transition-none desktop:group-hover:translate-x-0 desktop:group-hover:opacity-100",
            circleClasses[variant],
          ]}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
          >
            <path d={arrowPaths[arrowDirection]} />
          </svg>
        </span>
      </>
    ) : hasOutlineArrow ? (
      <>
        <span class="transition-[translate] duration-300 ease-out motion-reduce:transition-none desktop:group-hover:-translate-x-2">
          <slot />
        </span>
        <span
          aria-hidden="true"
          class:list={[
            "pointer-events-none absolute top-1/2 right-2 grid size-9 translate-x-[160%] -translate-y-1/2 place-items-center rounded-full opacity-0 transition-[translate,opacity] duration-300 ease-out motion-reduce:transition-none desktop:group-hover:translate-x-0 desktop:group-hover:opacity-100",
            circleClasses[variant],
          ]}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d={arrowPaths[arrowDirection]} />
          </svg>
        </span>
      </>
    ) : (
      <slot />
    )
  }
</Tag>
