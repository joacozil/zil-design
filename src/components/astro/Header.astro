---
import { NAV_LINKS } from "../../config/nav";
import MobileMenu from "../react/MobileMenu.tsx";
import logo from "../../assets/logo.svg";
---

<header
  class="fixed inset-x-0 top-0 z-40 bg-surface transition-transform duration-300 ease-out motion-reduce:transition-none"
  data-header
>
  <div
    class="mx-auto flex h-20 w-full max-w-8xl items-center justify-between px-6 tablet:px-8 desktop:px-12"
  >
    {/* Left: logo (recolored Zil Design violet) */}
    <a href="#hero" class="shrink-0" aria-label="Zil Design — inicio">
      <img
        src={logo.src}
        alt="Zil Design"
        width="50"
        height="28"
        class="h-7 w-auto"
      />
    </a>

    {/* Right: inline nav (desktop) + hamburger (mobile / tablet) */}
    <div class="flex items-center gap-3">
      <nav
        class="hidden items-center gap-8 desktop:flex"
        aria-label="Principal"
      >
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="text-p-sm font-medium text-text/70 transition-colors duration-200 hover:text-text"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      {
        /* No Contacto button here on mobile/tablet — ContactDrawer is the
          persistent invitation at those sizes, and two competing asks in one
          viewport is one too many. The inline nav above still carries Contacto
          on desktop, where the drawer is hidden. */
      }
      <MobileMenu client:load logoSrc={logo.src} />
    </div>
  </div>
</header>

<script>
  // Hide-on-scroll header: scrolling down slides it away, any upward scroll
  // brings it back. The 4px dead zone swallows scroll jitter (iOS momentum
  // wobble, trackpad noise) so the header doesn't flicker at rest, and the
  // `y > 120` guard keeps it visible near the top — including during iOS
  // rubber-band bounces, which report negative scrollY.
  const header = document.querySelector<HTMLElement>("[data-header]");
  let last = window.scrollY;
  let ticking = false;

  window.addEventListener(
    "scroll",
    () => {
      if (ticking || !header) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const delta = y - last;
        if (Math.abs(delta) > 4) {
          if (delta > 0 && y > 120) {
            header.classList.add("-translate-y-full");
          } else {
            header.classList.remove("-translate-y-full");
          }
        }
        last = y;
        ticking = false;
      });
    },
    { passive: true },
  );
</script>
