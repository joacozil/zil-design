---
import { NAV_LINKS } from "../../config/nav";
import MobileMenu from "../react/MobileMenu.tsx";
import logo from "../../assets/logo.svg";
---

{
  /* Floating pill header: the bar detaches from the viewport edges and rides as
    a rounded, shadowed island over the content. It stays solid `bg-surface` at
    all scroll positions (so the violet logo and dark nav are always legible) —
    the float is the whole effect. The outer <header> owns only positioning + the
    hide-on-scroll transform; the pt is the gap it floats below the top edge. */
}
<header
  class="header-intro fixed inset-x-0 top-0 z-40 transition-transform duration-300 ease-out motion-reduce:transition-none"
  data-header
>
  <div
    class="mx-auto flex w-full max-w-8xl px-6 pt-4 tablet:px-8 desktop:px-12"
  >
    <div
      class="flex w-full items-center justify-between gap-6 border border-border/60 bg-surface px-6 py-2 shadow-lg tablet:px-8 desktop:py-4"
    >
      {/* Left: logo (recolored Zil Design violet) */}
      <a href="#hero" class="shrink-0" aria-label="Zil Design — inicio">
        <img
          src={logo.src}
          alt="Zil Design"
          width="50"
          height="28"
          class="h-6 w-auto"
        />
      </a>

      {/* Right: inline nav (desktop) + hamburger (mobile / tablet) */}
      <div class="flex items-center gap-3">
        <nav
          class="hidden items-center gap-8 desktop:flex"
          aria-label="Principal"
        >
          {
            NAV_LINKS.map((link) => (
              <a
                href={link.href}
                class="text-p-sm font-medium text-text/70 transition-colors duration-200 hover:text-text"
              >
                {link.label}
              </a>
            ))
          }
        </nav>
        {
          /* No Contacto button here on mobile/tablet — ContactDrawer is the
          persistent invitation at those sizes, and two competing asks in one
          viewport is one too many. The inline nav above still carries Contacto
          on desktop, where the drawer is hidden. */
        }
        <MobileMenu client:load logoSrc={logo.src} />
      </div>
    </div>
  </div>
</header>

{
  /* Initial entrance: the bar slides down from above the top edge on load, the
    same transform-and-ease gesture the hide-on-scroll uses when it re-appears.
    Pure CSS so it needs no JS and can't leave the header stranded off-screen;
    reduced-motion readers get it already in place. It animates transform only,
    so it never fights the class-toggled `-translate-y-full` once it has run. */
}
<style>
  @keyframes header-slide-in {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  .header-intro {
    /* Matches the hide-on-scroll transition exactly (duration-300 ease-out). */
    animation: header-slide-in 0.3s ease-out both;
  }

  @media (prefers-reduced-motion: reduce) {
    .header-intro {
      animation: none;
    }
  }
</style>

<script>
  // Hide-on-scroll header: scrolling down slides it away, any upward scroll
  // brings it back. The 4px dead zone swallows scroll jitter (iOS momentum
  // wobble, trackpad noise) so the header doesn't flicker at rest, and the
  // `y > 120` guard keeps it visible near the top — including during iOS
  // rubber-band bounces, which report negative scrollY.
  const header = document.querySelector<HTMLElement>("[data-header]");
  let last = window.scrollY;
  let ticking = false;

  window.addEventListener(
    "scroll",
    () => {
      if (ticking || !header) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const delta = y - last;
        if (Math.abs(delta) > 4) {
          if (delta > 0 && y > 120) {
            header.classList.add("-translate-y-full");
          } else {
            header.classList.remove("-translate-y-full");
          }
        }
        last = y;
        ticking = false;
      });
    },
    { passive: true },
  );
</script>
